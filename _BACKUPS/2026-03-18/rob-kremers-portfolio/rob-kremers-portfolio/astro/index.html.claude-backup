<script>
// ===== CONSTANTS =====
const BASE_DATE = new Date('2014-10-01T00:00:00Z'); // Astro's DOGE entry
const TWO_PI = Math.PI * 2;
const METONIC_PERIOD = 231;
const APSIDAL_PERIOD = 109;
const SOLAR_PERIOD = 134;
const WAVE_SCALE = 0.4143 * 0.97;
const MEMORY_BASE = 0.69;

const COINGECKO_BASE = 'https://api.coingecko.com/api/v3';

// ===== STATE =====
let state = {
  token: 'dogecoin',
  price: 0,
  priceHistory: [],
  refreshInterval: 300000,
  timer: null,
  tradeHistory: [],
  lastSignal: null,
  backtestDone: false,
  historicalPrices: []
};

// ===== UTILITY =====
function daysSince(date) {
  return (date - BASE_DATE) / 86400000;
}

function fmt(n, decimals = 4) {
  if (n === null || n === undefined || isNaN(n)) return '--';
  return n.toFixed(decimals);
}

function fmtPct(n) {
  if (n === null || n === undefined || isNaN(n)) return '--';
  const sign = n >= 0 ? '+' : '';
  return sign + (n * 100).toFixed(2) + '%';
}

function fmtLargePct(n) {
  if (n === null || n === undefined || isNaN(n)) return '--';
  const sign = n >= 0 ? '+' : '';
  return sign + n.toFixed(1) + '%';
}

function fmtMoney(n) {
  if (!n) return '--';
  if (n >= 1e9) return '$' + (n / 1e9).toFixed(2) + 'B';
  if (n >= 1e6) return '$' + (n / 1e6).toFixed(2) + 'M';
  return '$' + n.toFixed(0);
}

function clamp(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }

function sigmoid(x) { return 1 / (1 + Math.exp(-x)); }

// ===== CYCLE ENGINE =====
function calcCycles(date) {
  const d = daysSince(date);
  const metonic = Math.sin(TWO_PI * d / METONIC_PERIOD);
  const apsidal = Math.sin(TWO_PI * d / APSIDAL_PERIOD);
  const solar = Math.sin(TWO_PI * d / SOLAR_PERIOD);
  const wave = (metonic + apsidal + solar) * WAVE_SCALE;
  return { metonic, apsidal, solar, wave, d };
}

function calcWave(date) {
  return calcCycles(date).wave;
}

// ===== CEA: Cycle Energy Alignment =====
// Reverse-engineered: measures phase coherence of three cycles using circular statistics
// Astro's known range: mean ~1.022, max ~5.378, volatility ~0.940
function calcCEA(date) {
  const { metonic, apsidal, solar, d } = calcCycles(date);

  // Convert to phase angles
  const phaseM = TWO_PI * d / METONIC_PERIOD % TWO_PI;
  const phaseA = TWO_PI * d / APSIDAL_PERIOD % TWO_PI;
  const phaseS = TWO_PI * d / SOLAR_PERIOD % TWO_PI;

  // Circular mean resultant length (Rayleigh statistic) — measures phase clustering
  const sinSum = Math.sin(phaseM) + Math.sin(phaseA) + Math.sin(phaseS);
  const cosSum = Math.cos(phaseM) + Math.cos(phaseA) + Math.cos(phaseS);
  const R = Math.sqrt(sinSum * sinSum + cosSum * cosSum) / 3; // 0=dispersed, 1=aligned

  // Amplitude component: how energetically active are the cycles
  const ampM = Math.abs(metonic);
  const ampA = Math.abs(apsidal);
  const ampS = Math.abs(solar);
  const ampMean = (ampM + ampA + ampS) / 3;

  // Phase alignment × energy → CEA
  // Calibrated to match Astro's known range (mean ~1.022, max ~5.378)
  const rawCEA = (1 + R * 4.378) * (0.7 + ampMean * 0.6);
  const cea = clamp(rawCEA, 0.5, 5.378);

  return cea;
}

// ===== LPI: Leading Phase Indicator =====
// Reverse-engineered: 3-5 day leading indicator using 2nd derivative + forward projection
// Astro's known range: 0-1, leads surges by 3-5 days
function calcLPI(date) {
  const t0 = calcWave(date);
  const t1 = calcWave(new Date(date.getTime() - 86400000));
  const t2 = calcWave(new Date(date.getTime() - 2 * 86400000));
  const t3 = calcWave(new Date(date.getTime() - 3 * 86400000));

  // 1st derivative (momentum)
  const dWave = t0 - t1;
  // 2nd derivative (acceleration)
  const d2Wave = (t0 - 2 * t1 + t2);
  // 3rd derivative (jerk)
  const d3Wave = (t0 - 3 * t1 + 3 * t2 - t3);

  // Project 4 days ahead (midpoint of 3-5 day range) using Taylor expansion
  const projected = t0 + dWave * 4 + d2Wave * 8 + d3Wave * (8 / 3);

  // LPI: normalized to 0-1
  // High LPI (>0.7) = surge signal ahead; Low LPI (<0.3) = dip ahead
  const lpi = clamp(0.5 + Math.tanh(projected * 2.5) * 0.5, 0, 1);
  return lpi;
}

// ===== PHYSICS METRICS =====
function calcPhysics(date, prices) {
  const { metonic, apsidal, solar, wave, d } = calcCycles(date);

  // Momentum (wave derivative)
  const prevWave = calcWave(new Date(date.getTime() - 86400000));
  const momentum = wave - prevWave;

  // Volatility from price history
  let volatility = 0.1;
  if (prices && prices.length > 5) {
    const slice = prices.slice(-14);
    const mean = slice.reduce((a, b) => a + b, 0) / slice.length;
    const variance = slice.reduce((s, p) => s + Math.pow(p - mean, 2), 0) / slice.length;
    volatility = clamp(Math.sqrt(variance) / mean, 0.001, 1.0);
  }

  const energy = Math.abs(momentum) * volatility;
  const phaseAccel = Math.abs(solar) > 0.7 ? Math.abs(momentum) : 0;
  const curvature = 1 + Math.sin(TWO_PI * d / 180);
  const memory = MEMORY_BASE * (1 + volatility);
  const stress = volatility * (1 - Math.cos(wave));

  // Improved attractor: uses phase difference between all three cycles
  const phaseDiffMA = Math.abs(metonic - apsidal);
  const phaseDiffMS = Math.abs(metonic - solar);
  const phaseDiffAS = Math.abs(apsidal - solar);
  const avgPhaseDiff = (phaseDiffMA + phaseDiffMS + phaseDiffAS) / 3;
  const attractor = avgPhaseDiff < 0.3 ? 2.0 : avgPhaseDiff < 0.6 ? 1.5 : 1.0;

  const cea = calcCEA(date);
  const lpi = calcLPI(date);

  return { metonic, apsidal, solar, wave, momentum, volatility, energy, phaseAccel, curvature, memory, stress, attractor, cea, lpi };
}

// ===== SIGNAL GENERATION (IMPROVED) =====
function generateSignal(metrics) {
  const { wave, momentum, energy, attractor, phaseAccel, volatility, lpi, cea } = metrics;

  // Adaptive thresholds based on volatility regime
  const buyWaveThreshold = volatility > 0.3 ? -0.15 : -0.20;  // tighter in low vol
  const buyMomentumThreshold = volatility > 0.3 ? 0.002 : 0.001;
  const buyEnergyThreshold = volatility > 0.3 ? 0.25 : 0.20;

  const sellWaveExhaust = 0.75;
  const sellWaveTurn = volatility > 0.3 ? 0.35 : 0.40;
  const sellMomentumThreshold = -0.04;

  let signal = 'HOLD';
  let confidence = 30;
  let strength = 30;

  // BUY conditions (improved with CEA and LPI)
  const coreByConditions =
    wave > buyWaveThreshold &&
    momentum > buyMomentumThreshold &&
    energy > buyEnergyThreshold;

  const ceaBoost = cea > 1.0;
  const lpiBoost = lpi > 0.65;

  if (coreByConditions) {
    signal = 'BUY';
    confidence = clamp((Math.abs(momentum) * 100 + energy * 100) / 2, 20, 100);
    // Boost confidence if CEA and LPI agree
    if (ceaBoost) confidence = clamp(confidence * 1.2, 0, 100);
    if (lpiBoost) confidence = clamp(confidence * 1.15, 0, 100);
    strength = clamp(attractor * 20 + phaseAccel * 50 + (1 - volatility) * 30, 0, 100);
  }

  // SELL conditions
  const sellExhausted = wave > sellWaveExhaust;
  const sellTurning = wave > sellWaveTurn && momentum < sellMomentumThreshold;
  const ceaSell = cea < 0.8 && wave > 0.3;

  if (sellExhausted || sellTurning || ceaSell) {
    signal = 'SELL';
    confidence = clamp((Math.abs(momentum) * 100 + energy * 50) / 2, 20, 100);
    if (sellExhausted) confidence = clamp(confidence * 1.3, 0, 100);
    strength = clamp(volatility * 100, 10, 100);
  }

  // CEA very low = strong hold/avoid
  if (cea < 0.7 && signal === 'BUY') {
    signal = 'HOLD';
    confidence = 25;
  }

  return { signal, confidence: Math.round(confidence), strength: Math.round(strength) };
}

// ===== RISK SCORE =====
function calcRiskScore(metrics, confidence) {
  const { wave, energy, volatility, cea, lpi } = metrics;
  let score = 50
    + (wave * 30)
    + (energy * 20)
    - (volatility * 30)
    + (confidence * 0.2)
    + (cea > 1.0 ? (cea - 1.0) * 5 : (cea - 1.0) * 8)  // CEA influence
    + ((lpi - 0.5) * 15);  // LPI influence
  return Math.round(clamp(score, 0, 100));
}

// ===== MARKET DECISION =====
function getMarketDecision(signal, riskScore, lpi, cea) {
  if (signal === 'BUY' && riskScore >= 70 && cea >= 1.5 && lpi >= 0.7)
    return { text: '🟢 STRONG BUY', detail: 'Full alignment: CEA bullish, LPI surge ahead, wave rising' };
  if (signal === 'BUY' && riskScore >= 65)
    return { text: '🟢 BUY', detail: 'Cycles and momentum aligned, risk favorable' };
  if (signal === 'BUY' && riskScore >= 50)
    return { text: '🟡 LIGHT BUY', detail: 'Moderate setup, consider scaling in' };
  if (signal === 'SELL' && riskScore >= 65)
    return { text: '🔴 STRONG SELL', detail: 'Wave exhaustion + cycle divergence' };
  if (signal === 'SELL' && riskScore >= 50)
    return { text: '🟠 TAKE PROFITS', detail: 'Momentum fading, reduce exposure' };
  if (riskScore < 35)
    return { text: '🟢 ACCUMULATE', detail: 'Low risk environment, below-average wave' };
  return { text: '⚪ HOLD / WAIT', detail: 'No clear edge, stay patient' };
}

// ===== MARKET REGIME DETECTION =====
function detectRegime(prices, wave, volatility) {
  if (!prices || prices.length < 20) return { regime: 'neutral', label: 'NEUTRAL' };

  const recent = prices.slice(-14);
  const prev = prices.slice(-28, -14);
  const recentMean = recent.reduce((a, b) => a + b, 0) / recent.length;
  const prevMean = prev.reduce((a, b) => a + b, 0) / prev.length;
  const trendDir = recentMean - prevMean;

  if (wave > 0.2 && trendDir > 0 && volatility < 0.4) return { regime: 'bull', label: 'BULL' };
  if (wave < -0.1 && trendDir < 0) return { regime: 'bear', label: 'BEAR' };
  return { regime: 'neutral', label: 'NEUTRAL' };
}

// ===== SYSTEM CONFIDENCE =====
function calcSystemConfidence(metrics, signal) {
  const { wave, momentum, energy, attractor, cea, lpi } = metrics;
  let agreements = 0;
  const total = 6;

  if (signal === 'BUY') {
    if (wave > 0) agreements++;
    if (momentum > 0) agreements++;
    if (energy > 0.2) agreements++;
    if (attractor >= 1.5) agreements++;
    if (cea >= 1.0) agreements++;
    if (lpi >= 0.6) agreements++;
  } else if (signal === 'SELL') {
    if (wave > 0.4) agreements++;
    if (momentum < 0) agreements++;
    if (energy > 0.1) agreements++;
    if (attractor < 1.5) agreements++;
    if (cea < 1.0) agreements++;
    if (lpi < 0.4) agreements++;
  } else {
    if (Math.abs(wave) < 0.3) agreements++;
    if (Math.abs(momentum) < 0.02) agreements++;
    agreements += 2;
    if (cea > 0.8 && cea < 1.5) agreements++;
    if (lpi > 0.4 && lpi < 0.6) agreements++;
  }

  return Math.round((agreements / total) * 100);
}

// ===== 90-DAY FORECAST =====
function generateForecast(startDate) {
  const windows = [];
  let prevWave = calcWave(startDate);

  for (let i = 1; i <= 90; i++) {
    const d = new Date(startDate.getTime() + i * 86400000);
    const w = calcWave(d);
    const m = w - prevWave;
    const lpi = calcLPI(d);
    const cea = calcCEA(d);

    // BUY window: wave crosses above threshold from below with positive momentum
    if (prevWave <= -0.15 && w > -0.15 && m > 0) {
      windows.push({
        type: 'BUY', date: d,
        wave: w,
        strength: Math.round(clamp(Math.abs(m) * 200 + cea * 10, 20, 100)),
        lpi: lpi, cea: cea
      });
    }

    // SELL window: wave reaches exhaustion
    if (w > 0.7 && prevWave <= 0.7) {
      windows.push({
        type: 'SELL', date: d,
        wave: w,
        strength: Math.round(clamp(w * 80 + Math.abs(m) * 200, 20, 100)),
        lpi: lpi, cea: cea
      });
    }

    // LPI-based early warning
    if (lpi > 0.82 && i > 5) {
      windows.push({
        type: 'BUY', date: d,
        wave: w,
        strength: Math.round(lpi * 80),
        lpi: lpi, cea: cea,
        label: '⚡ LPI Alert'
      });
    }

    prevWave = w;
  }

  // Deduplicate windows within 5 days
  const deduped = [];
  for (const win of windows) {
    const overlaps = deduped.some(w =>
      w.type === win.type &&
      Math.abs(w.date - win.date) < 5 * 86400000
    );
    if (!overlaps) deduped.push(win);
  }

  return deduped.slice(0, 12).sort((a, b) => a.date - b.date);
}

// ===== REAL HISTORICAL BACKTEST =====
async function fetchHistoricalPrices(coinId, days = 365) {
  try {
    const url = `${COINGECKO_BASE}/coins/${coinId}/market_chart?vs_currency=usd&days=${days}&interval=daily`;
    const resp = await fetch(url);
    if (!resp.ok) throw new Error('API error ' + resp.status);
    const data = await resp.json();
    return data.prices.map(([ts, p]) => ({ date: new Date(ts), price: p }));
  } catch (e) {
    console.warn('fetchHistoricalPrices failed:', e);
    return null;
  }
}

function runBacktest(historicalData) {
  if (!historicalData || historicalData.length < 30) return null;

  const initialEquity = 10000;
  let astroEquity = initialEquity;
  let bhEquity = initialEquity;
  const initialPrice = historicalData[0].price;
  const trades = [];
  let inPosition = false;
  let entryPrice = 0;
  let entryDate = null;
  let entryIdx = 0;
  const returns = [];

  for (let i = 1; i < historicalData.length; i++) {
    const { date, price } = historicalData[i];
    const prevPrice = historicalData[i - 1].price;

    // Build mini price history for volatility
    const miniHistory = historicalData.slice(Math.max(0, i - 14), i).map(d => d.price);

    const metrics = calcPhysics(date, miniHistory);
    const prevMetrics = calcPhysics(historicalData[i - 1].date, miniHistory.slice(0, -1));
    const { signal } = generateSignal(metrics);

    // Buy & Hold equity
    bhEquity = initialEquity * (price / initialPrice);

    if (signal === 'BUY' && !inPosition) {
      entryPrice = price;
      entryDate = date;
      entryIdx = i;
      inPosition = true;
    } else if ((signal === 'SELL' || signal === 'HOLD') && inPosition) {
      const pnl = (price - entryPrice) / entryPrice;
      const fee = 0.0025; // 0.25% round-trip fee
      const netPnl = pnl - fee;
      astroEquity *= (1 + netPnl);
      returns.push(netPnl);
      trades.push({
        entry: entryPrice, exit: price, return: netPnl,
        entryDate, exitDate: date,
        holdDays: Math.round((date - entryDate) / 86400000),
        signal: signal
      });
      inPosition = false;
    }
  }

  // Close open position
  if (inPosition && historicalData.length > 0) {
    const lastPrice = historicalData[historicalData.length - 1].price;
    const pnl = (lastPrice - entryPrice) / entryPrice;
    astroEquity *= (1 + pnl - 0.0025);
    returns.push(pnl - 0.0025);
  }

  // Metrics
  const winRate = trades.filter(t => t.return > 0).length / Math.max(1, trades.length);
  const avgReturn = returns.reduce((a, b) => a + b, 0) / Math.max(1, returns.length);
  const stdReturn = returns.length > 1
    ? Math.sqrt(returns.reduce((s, r) => s + Math.pow(r - avgReturn, 2), 0) / (returns.length - 1))
    : 0.01;
  const sharpe = stdReturn > 0 ? (avgReturn / stdReturn) * Math.sqrt(252) : 0;
  const astroReturn = (astroEquity - initialEquity) / initialEquity * 100;
  const bhReturn = (bhEquity - initialEquity) / initialEquity * 100;

  return {
    astroReturn, bhReturn, winRate, sharpe,
    trades, astroEquity, bhEquity,
    tradeCount: trades.length
  };
}

// ===== CHART RENDERING =====
function drawForecastChart(canvas, startDate) {
  const ctx = canvas.getContext('2d');
  const W = canvas.offsetWidth;
  const H = canvas.height;
  canvas.width = W;
  ctx.clearRect(0, 0, W, H);

  const days = 90;
  const points = [];
  const lpiPoints = [];
  const ceaPoints = [];

  for (let i = 0; i <= days; i++) {
    const d = new Date(startDate.getTime() + i * 86400000);
    const w = calcWave(d);
    const lpi = calcLPI(d);
    const cea = calcCEA(d);
    points.push(w);
    lpiPoints.push(lpi);
    ceaPoints.push((cea - 0.5) / 4.878); // normalize CEA to 0-1
  }

  const minW = Math.min(...points);
  const maxW = Math.max(...points);
  const range = maxW - minW || 1;
  const toY = v => H - 10 - ((v - minW) / range) * (H - 20);
  const toX = i => (i / days) * W;

  // Background grid
  ctx.strokeStyle = '#1a1a4e';
  ctx.lineWidth = 1;
  for (let g = 0; g <= 4; g++) {
    const y = 10 + g * (H - 20) / 4;
    ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(W, y); ctx.stroke();
  }

  // Zero line
  const zeroY = toY(0);
  ctx.strokeStyle = '#334488'; ctx.lineWidth = 1.5;
  ctx.setLineDash([4, 4]);
  ctx.beginPath(); ctx.moveTo(0, zeroY); ctx.lineTo(W, zeroY); ctx.stroke();
  ctx.setLineDash([]);

  // Today marker
  const todayX = 0;
  ctx.strokeStyle = '#ffcc00'; ctx.lineWidth = 1;
  ctx.beginPath(); ctx.moveTo(todayX, 0); ctx.lineTo(todayX, H); ctx.stroke();
  ctx.fillStyle = '#ffcc00'; ctx.font = '10px monospace';
  ctx.fillText('TODAY', todayX + 4, 14);

  // CEA fill (behind)
  ctx.beginPath();
  ctx.moveTo(toX(0), H);
  for (let i = 0; i <= days; i++) {
    const ceaNorm = ceaPoints[i];
    ctx.lineTo(toX(i), H - ceaNorm * (H * 0.3));
  }
  ctx.lineTo(toX(days), H); ctx.closePath();
  ctx.fillStyle = 'rgba(0,212,255,0.06)';
  ctx.fill();

  // LPI line
  ctx.beginPath();
  for (let i = 0; i <= days; i++) {
    const y = H - 10 - lpiPoints[i] * (H - 20);
    i === 0 ? ctx.moveTo(toX(i), y) : ctx.lineTo(toX(i), y);
  }
  ctx.strokeStyle = 'rgba(255,0,170,0.5)'; ctx.lineWidth = 1.5;
  ctx.stroke();

  // Wave fill: green above zero, red below
  for (let i = 0; i < days; i++) {
    const x1 = toX(i), x2 = toX(i + 1);
    const y1 = toY(points[i]), y2 = toY(points[i + 1]);
    const color = points[i] >= 0 ? 'rgba(0,255,136,0.3)' : 'rgba(255,68,85,0.3)';
    ctx.beginPath();
    ctx.moveTo(x1, zeroY); ctx.lineTo(x1, y1);
    ctx.lineTo(x2, y2); ctx.lineTo(x2, zeroY);
    ctx.closePath();
    ctx.fillStyle = color; ctx.fill();
  }

  // Main wave line
  ctx.beginPath();
  for (let i = 0; i <= days; i++) {
    i === 0 ? ctx.moveTo(toX(i), toY(points[i])) : ctx.lineTo(toX(i), toY(points[i]));
  }
  ctx.strokeStyle = var_cyan(); ctx.lineWidth = 2;
  ctx.stroke();

  // Forecast windows
  const windows = generateForecast(startDate);
  for (const win of windows) {
    const dayOffset = Math.round((win.date - startDate) / 86400000);
    if (dayOffset < 0 || dayOffset > days) continue;
    const x = toX(dayOffset);
    ctx.fillStyle = win.type === 'BUY' ? 'rgba(0,255,136,0.8)' : 'rgba(255,68,85,0.8)';
    ctx.beginPath(); ctx.arc(x, toY(win.wave), 5, 0, TWO_PI); ctx.fill();
    ctx.fillStyle = win.type === 'BUY' ? '#00ff88' : '#ff4455';
    ctx.font = '9px monospace';
    ctx.fillText(win.type === 'BUY' ? 'B' : 'S', x - 3, toY(win.wave) - 8);
  }

  // Legend
  ctx.font = '10px monospace';
  ctx.fillStyle = var_cyan(); ctx.fillText('— WAVE', 6, H - 4);
  ctx.fillStyle = 'rgba(255,0,170,0.8)'; ctx.fillText('— LPI', 64, H - 4);
  ctx.fillStyle = 'rgba(0,212,255,0.5)'; ctx.fillText('▪ CEA', 108, H - 4);
}

function var_cyan() { return '#00d4ff'; }

function drawBacktestChart(canvas, historicalData, btResult) {
  if (!historicalData || historicalData.length < 2) return;
  const ctx = canvas.getContext('2d');
  const W = canvas.offsetWidth;
  const H = canvas.height;
  canvas.width = W;
  ctx.clearRect(0, 0, W, H);

  const n = historicalData.length;
  const astroEquityCurve = [10000];
  const bhEquityCurve = [10000];
  const initialPrice = historicalData[0].price;
  let astroEq = 10000;
  let inPos = false;
  let entryP = 0;

  for (let i = 1; i < n; i++) {
    const { date, price } = historicalData[i];
    const miniHist = historicalData.slice(Math.max(0, i - 14), i).map(d => d.price);
    const metrics = calcPhysics(date, miniHist);
    const { signal } = generateSignal(metrics);

    bhEquityCurve.push(10000 * (price / initialPrice));

    if (signal === 'BUY' && !inPos) { entryP = price; inPos = true; }
    if ((signal === 'SELL' || signal === 'HOLD') && inPos) {
      astroEq *= (1 + (price - entryP) / entryP - 0.0025);
      inPos = false;
    }
    astroEquityCurve.push(astroEq);
  }

  const allVals = [...astroEquityCurve, ...bhEquityCurve];
  const minV = Math.min(...allVals);
  const maxV = Math.max(...allVals);
  const range = maxV - minV || 1;
  const toY = v => H - 5 - ((v - minV) / range) * (H - 15);
  const toX = i => (i / (n - 1)) * W;

  // Grid
  ctx.strokeStyle = '#1a1a4e'; ctx.lineWidth = 1;
  for (let g = 0; g <= 3; g++) {
    const y = 5 + g * (H - 15) / 3;
    ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(W, y); ctx.stroke();
  }

  // BH curve
  ctx.beginPath();
  bhEquityCurve.forEach((v, i) => i === 0 ? ctx.moveTo(toX(i), toY(v)) : ctx.lineTo(toX(i), toY(v)));
  ctx.strokeStyle = '#334488'; ctx.lineWidth = 1.5; ctx.stroke();

  // Astro curve
  ctx.beginPath();
  astroEquityCurve.forEach((v, i) => i === 0 ? ctx.moveTo(toX(i), toY(v)) : ctx.lineTo(toX(i), toY(v)));
  ctx.strokeStyle = var_cyan(); ctx.lineWidth = 2.5; ctx.stroke();

  // Trade markers
  if (btResult) {
    for (const trade of btResult.trades) {
      const entryDay = historicalData.findIndex(d => Math.abs(d.date - trade.entryDate) < 86400000 * 2);
      const exitDay = historicalData.findIndex(d => Math.abs(d.date - trade.exitDate) < 86400000 * 2);
      if (entryDay >= 0) {
        ctx.fillStyle = '#00ff88'; ctx.beginPath(); ctx.arc(toX(entryDay), toY(astroEquityCurve[entryDay] || 10000), 3, 0, TWO_PI); ctx.fill();
      }
      if (exitDay >= 0) {
        ctx.fillStyle = trade.return > 0 ? '#00ff88' : '#ff4455'; ctx.beginPath(); ctx.arc(toX(exitDay), toY(astroEquityCurve[exitDay] || 10000), 3, 0, TWO_PI); ctx.fill();
      }
    }
  }

  // Legend
  ctx.font = '10px monospace';
  ctx.fillStyle = var_cyan(); ctx.fillText('— ASTRO', 6, H - 4);
  ctx.fillStyle = '#334488'; ctx.fillText('— BUY & HOLD', 72, H - 4);
}

