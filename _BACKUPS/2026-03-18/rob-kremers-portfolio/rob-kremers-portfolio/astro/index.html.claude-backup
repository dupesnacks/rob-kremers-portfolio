  if (state.priceHistory.length > 0) {
    const hi52 = Math.max(...state.priceHistory);
    const lo52 = Math.min(...state.priceHistory);
    setEl('high-52w', '$' + hi52.toFixed(4));
    setEl('low-52w', '$' + lo52.toFixed(4));
    const fromAth = (data.price - hi52) / hi52 * 100;
    const athEl = document.getElementById('from-ath');
    athEl.textContent = fmtPct(fromAth / 100);
    athEl.style.color = fromAth >= 0 ? 'var(--green)' : 'var(--red)';
  }

  // Signal
  const sb = document.getElementById('signal-box');
  const sl = document.getElementById('signal-label');
  sb.className = 'signal-box ' + signal.toLowerCase();
  sl.className = 'signal-label ' + signal.toLowerCase();
  sl.textContent = signal;
  setEl('signal-decision', decision.text + ' — ' + decision.detail);

  setEl('confidence', confidence + '%');
  setBar('conf-bar', confidence);
  setEl('strength', strength + '%');
  setBar('str-bar', strength);
  setEl('sys-conf', systemConf + '%');
  setBar('sys-conf-bar', systemConf);

  const regimePill = document.getElementById('regime-pill');
  regimePill.textContent = regime.label;
  regimePill.className = 'regime-pill regime-' + regime.regime;
  setEl('regime-text', regime.regime === 'bull' ? 'Uptrend — cycles & price aligned'
    : regime.regime === 'bear' ? 'Downtrend — avoid long exposure'
    : 'Sideways — wait for clearer signal');

  // Risk score
  const rsEl = document.getElementById('risk-score');
  rsEl.textContent = riskScore;
  rsEl.style.color = riskScore >= 65 ? 'var(--green)' : riskScore >= 40 ? 'var(--yellow)' : 'var(--red)';
  setBar('risk-bar', riskScore);
  setEl('risk-label', riskScore >= 70 ? '/ 100 — RISK ON' : riskScore >= 40 ? '/ 100 — NEUTRAL' : '/ 100 — RISK OFF');

  const riskInterp = document.getElementById('risk-interpretation');
  if (riskScore >= 70) riskInterp.innerHTML = '<span style="color:var(--green)">✅ Full risk-on. Cycles favor upside. Consider full allocation.</span>';
  else if (riskScore >= 55) riskInterp.innerHTML = '<span style="color:var(--yellow)">⚠️ Moderate risk. Partial allocation recommended.</span>';
  else if (riskScore >= 40) riskInterp.innerHTML = '<span style="color:var(--yellow)">⏸️ Neutral zone. Hold existing positions, no new entries.</span>';
  else riskInterp.innerHTML = '<span style="color:var(--red)">🛑 Risk off. Protect capital. Cycles unfavorable.</span>';

  setEl('wave-val', fmt(wave, 4));
  setEl('momentum-val', fmt(momentum, 5));
  const trendEl = document.getElementById('trend-val');
  if (momentum > 0.002) { trendEl.textContent = '↑ Rising'; trendEl.style.color = 'var(--green)'; }
  else if (momentum < -0.002) { trendEl.textContent = '↓ Falling'; trendEl.style.color = 'var(--red)'; }
  else { trendEl.textContent = '→ Flat'; trendEl.style.color = 'var(--yellow)'; }

  // CEA
  const ceaRounded = cea.toFixed(3);
  setEl('cea-val', ceaRounded);
  const ceaStatus = document.getElementById('cea-status');
  if (cea >= 1.5) { ceaStatus.innerHTML = '<span class="cea-badge" style="background:rgba(0,255,136,.2);border-color:var(--green);color:var(--green)">STRONG BULLISH</span>'; }
  else if (cea >= 1.0) { ceaStatus.innerHTML = '<span class="cea-badge">BULLISH</span>'; }
  else if (cea >= 0.8) { ceaStatus.innerHTML = '<span class="cea-badge" style="border-color:var(--yellow);color:var(--yellow)">NEUTRAL</span>'; }
  else { ceaStatus.innerHTML = '<span class="cea-badge" style="border-color:var(--red);color:var(--red)">BEARISH</span>'; }
  setEl('cea-signal', cea >= 1.0 ? '✅ Bullish alignment' : '⛔ Bearish / neutral');
  setBar('cea-bar', (cea / 5.378) * 100);

  // LPI
  setEl('lpi-val', lpi.toFixed(3));
  const lpiStatus = document.getElementById('lpi-status');
  if (lpi >= 0.75) { lpiStatus.innerHTML = '<span class="lpi-badge" style="background:rgba(0,255,136,.2);border-color:var(--green);color:var(--green)">⚡ SURGE AHEAD</span>'; }
  else if (lpi >= 0.60) { lpiStatus.innerHTML = '<span class="lpi-badge">BULLISH AHEAD</span>'; }
  else if (lpi >= 0.40) { lpiStatus.innerHTML = '<span class="lpi-badge" style="border-color:var(--yellow);color:var(--yellow)">NEUTRAL</span>'; }
  else { lpiStatus.innerHTML = '<span class="lpi-badge" style="border-color:var(--red);color:var(--red)">DIP AHEAD</span>'; }
  const lpiFC = document.getElementById('lpi-forecast');
  lpiFC.textContent = lpi >= 0.75 ? '⚡ Surge likely in 3-5 days'
    : lpi >= 0.60 ? '↑ Positive move in 3-5 days'
    : lpi < 0.35 ? '↓ Possible dip in 3-5 days'
    : '→ No strong signal';
  lpiFC.style.color = lpi >= 0.60 ? 'var(--green)' : lpi < 0.35 ? 'var(--red)' : 'var(--yellow)';
  setBar('lpi-bar', lpi * 100);

  // Physics engine
  setEl('metonic', fmt(metonic, 4));
  setEl('apsidal', fmt(apsidal, 4));
  setEl('solar', fmt(solar, 4));
  setBar('metonic-bar', (metonic + 1) / 2 * 100);
  setBar('apsidal-bar', (apsidal + 1) / 2 * 100);
  setBar('solar-bar', (solar + 1) / 2 * 100);
  setEl('energy', fmt(energy, 4));
  setEl('attractor', fmt(attractor, 3));
  setEl('phase-accel', fmt(phaseAccel, 4));
  setEl('curvature', fmt(curvature, 4));
  setEl('memory', fmt(memory, 4));
  setEl('stress', fmt(stress, 4));
}

function updateForecastWindows(windows) {
  const el = document.getElementById('forecast-windows');
  if (!windows.length) { el.innerHTML = '<div style="color:var(--dim)">No clear windows in 90 days</div>'; return; }
  el.innerHTML = windows.map(w => `
    <div class="forecast-window fw-${w.type.toLowerCase()}">
      <span style="color:${w.type === 'BUY' ? 'var(--green)' : 'var(--red)'}">${w.type === 'BUY' ? '🟢' : '🔴'} ${w.type} ${w.label || ''}</span>
      <span>${w.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</span>
      <span style="color:var(--dim)">${w.strength}%</span>
    </div>`).join('');
}

function updateTradeHistory(signal, price) {
  if (state.lastSignal === signal) return;
  state.lastSignal = signal;
  const now = new Date();
  state.tradeHistory.unshift({ signal, price, time: now });
  if (state.tradeHistory.length > 20) state.tradeHistory.pop();

  const el = document.getElementById('trade-history');
  el.innerHTML = state.tradeHistory.map(t => `
    <div class="trade-row trade-${t.signal.toLowerCase()}">
      <span>${t.signal === 'BUY' ? '🟢' : t.signal === 'SELL' ? '🔴' : '⚪'} ${t.signal}</span>
      <span>$${t.price >= 1 ? t.price.toFixed(4) : t.price.toFixed(6)}</span>
      <span style="color:var(--dim)">${t.time.toLocaleDateString()} ${t.time.toLocaleTimeString()}</span>
    </div>`).join('');
}

// ===== API LAYER =====
async function fetchCurrentPrice(coinId) {
  const url = `${COINGECKO_BASE}/coins/markets?vs_currency=usd&ids=${coinId}&order=market_cap_desc&per_page=1&page=1&sparkline=false&price_change_percentage=7d`;
  const resp = await fetch(url);
  if (!resp.ok) throw new Error('CoinGecko API error: ' + resp.status);
  const data = await resp.json();
  if (!data[0]) throw new Error('No data returned');
  const d = data[0];
  return {
    price: d.current_price,
    change24h: d.price_change_percentage_24h || 0,
    change7d: d.price_change_percentage_7d_in_currency || 0,
    marketCap: d.market_cap,
    volume: d.total_volume,
    high52w: d.high_24h, low52w: d.low_24h // Note: 24h highs used as placeholder
  };
}

// ===== MAIN REFRESH CYCLE =====
async function refresh() {
  try {
    setEl('last-update', 'Updating...');
    const data = await fetchCurrentPrice(state.token);
    state.price = data.price;
    state.priceHistory.push(data.price);
    if (state.priceHistory.length > 365) state.priceHistory.shift();

    const now = new Date();
    const metrics = calcPhysics(now, state.priceHistory);
    const sig = generateSignal(metrics);
    const riskScore = calcRiskScore(metrics, sig.confidence);
    const systemConf = calcSystemConfidence(metrics, sig.signal);
    const regime = detectRegime(state.priceHistory, metrics.wave, metrics.volatility);

    updateDashboard(data, metrics, sig, riskScore, systemConf, regime);
    updateTradeHistory(sig.signal, data.price);

    const now2 = new Date();
    const windows = generateForecast(now2);
    updateForecastWindows(windows);

    const canvas = document.getElementById('forecast-canvas');
    drawForecastChart(canvas, now2);

    updateStatus(true);
    setEl('last-update', 'Updated ' + now.toLocaleTimeString());

    return true;
  } catch (e) {
    console.error('Refresh error:', e);
    updateStatus(false, 'ERROR');
    setEl('last-update', 'Error: ' + e.message.substring(0, 40));
    return false;
  }
}

async function runRealBacktest() {
  const btLoading = document.getElementById('backtest-loading');
  const btResults = document.getElementById('backtest-results');
  btLoading.textContent = 'Fetching 365 days of real ' + state.token.toUpperCase() + ' price data from CoinGecko...';

  const historical = await fetchHistoricalPrices(state.token, 365);
  state.historicalPrices = historical;

  if (!historical || historical.length < 50) {
    btLoading.textContent = '⚠️ Could not fetch historical data. API may be rate-limited. Try refreshing.';
    return;
  }

  btLoading.textContent = `Running backtest on ${historical.length} days of real data...`;
  // Run in next tick to not block UI
  await new Promise(r => setTimeout(r, 50));

  const result = runBacktest(historical);
  if (!result) { btLoading.textContent = '⚠️ Backtest failed.'; return; }

  btLoading.style.display = 'none';
  btResults.style.display = 'block';

  const astroRetEl = document.getElementById('bt-astro-return');
  astroRetEl.textContent = fmtLargePct(result.astroReturn);
  astroRetEl.className = 'bt-val ' + (result.astroReturn >= 0 ? 'pos' : 'neg');

  const bhRetEl = document.getElementById('bt-bh-return');
  bhRetEl.textContent = fmtLargePct(result.bhReturn);
  bhRetEl.className = 'bt-val ' + (result.bhReturn >= 0 ? 'pos' : 'neg');

  setEl('bt-win-rate', (result.winRate * 100).toFixed(1) + '%');
  const sharpeEl = document.getElementById('bt-sharpe');
  sharpeEl.textContent = result.sharpe.toFixed(2);
  sharpeEl.className = 'bt-val ' + (result.sharpe >= 1 ? 'pos' : 'neg');

  const tradesList = document.getElementById('bt-trades-list');
  tradesList.innerHTML = result.trades.slice(-10).reverse().map(t => `
    <div class="trade-row ${t.return > 0 ? 'trade-buy' : 'trade-sell'}">
      <span>${t.return > 0 ? '✅' : '❌'} ${t.entryDate.toLocaleDateString()} → ${t.exitDate.toLocaleDateString()}</span>
      <span>${t.holdDays}d</span>
      <span>${t.return >= 0 ? '+' : ''}${(t.return * 100).toFixed(2)}%</span>
    </div>`).join('');

  const btCanvas = document.getElementById('backtest-canvas');
  drawBacktestChart(btCanvas, historical, result);
}

// ===== INIT =====
async function init() {
  const loadMsg = document.getElementById('loading-msg');

  loadMsg.textContent = 'Fetching live ' + state.token + ' price...';
  const success = await refresh();

  if (success) {
    loadMsg.textContent = 'Fetching historical data for backtest...';
    await runRealBacktest();
  }

  document.getElementById('loading').style.display = 'none';
  state.backtestDone = true;

  // Start auto-refresh
  startRefreshTimer();
}

function startRefreshTimer() {
  if (state.timer) clearInterval(state.timer);
  state.timer = setInterval(refresh, state.refreshInterval);
}

function onTokenChange() {
  state.token = document.getElementById('token-select').value;
  state.priceHistory = [];
  state.historicalPrices = [];
  state.backtestDone = false;
  const btLoading = document.getElementById('backtest-loading');
  const btResults = document.getElementById('backtest-results');
  btLoading.style.display = 'block';
  btResults.style.display = 'none';
  btLoading.textContent = 'Switching token...';
  refresh().then(() => runRealBacktest());
}

function onRefreshChange() {
  state.refreshInterval = parseInt(document.getElementById('refresh-select').value);
  startRefreshTimer();
}

function manualRefresh() {
  refresh();
}

window.addEventListener('load', init);
window.addEventListener('resize', () => {
  const canvas = document.getElementById('forecast-canvas');
  if (canvas.offsetWidth > 0) drawForecastChart(canvas, new Date());
  const btCanvas = document.getElementById('backtest-canvas');
  if (btCanvas.offsetWidth > 0 && state.historicalPrices.length > 0) {
    const result = runBacktest(state.historicalPrices);
    drawBacktestChart(btCanvas, state.historicalPrices, result);
  }
});
