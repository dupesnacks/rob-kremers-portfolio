<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>⚛️ Astro Physics Trading Dashboard v2</title>
<style>
:root {
  --bg: #050510;
  --surface: #0a0a1e;
  --card: #0f0f2e;
  --border: #1a1a4e;
  --cyan: #00d4ff;
  --magenta: #ff00aa;
  --gold: #ffd700;
  --green: #00ff88;
  --red: #ff4455;
  --yellow: #ffcc00;
  --text: #c8d8ff;
  --dim: #556088;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { background: var(--bg); color: var(--text); font-family: 'Courier New', monospace; font-size: 13px; line-height: 1.5; }
header { background: linear-gradient(135deg, #050510 0%, #0a0a30 100%); border-bottom: 1px solid var(--cyan); padding: 12px 20px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 8px; }
header h1 { font-size: 18px; color: var(--cyan); letter-spacing: 2px; }
.header-right { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; }
#status-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--dim); display: inline-block; margin-right: 4px; }
#status-dot.live { background: var(--green); box-shadow: 0 0 8px var(--green); animation: pulse 2s infinite; }
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.4} }
.token-select { background: var(--card); border: 1px solid var(--border); color: var(--cyan); padding: 4px 8px; border-radius: 4px; cursor: pointer; font-family: inherit; font-size: 12px; }
.refresh-btn { background: var(--card); border: 1px solid var(--cyan); color: var(--cyan); padding: 4px 12px; border-radius: 4px; cursor: pointer; font-family: inherit; font-size: 12px; transition: all .2s; }
.refresh-btn:hover { background: var(--cyan); color: var(--bg); }
.grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 12px; padding: 12px; }
.card { background: var(--card); border: 1px solid var(--border); border-radius: 8px; padding: 14px; }
.card-title { color: var(--dim); font-size: 10px; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 10px; border-bottom: 1px solid var(--border); padding-bottom: 6px; }
.big-price { font-size: 32px; color: var(--gold); font-weight: bold; }
.price-change { font-size: 13px; margin-top: 4px; }
.price-change.up { color: var(--green); }
.price-change.down { color: var(--red); }
.metric-row { display: flex; justify-content: space-between; align-items: center; padding: 4px 0; border-bottom: 1px solid #111128; }
.metric-label { color: var(--dim); }
.metric-value { font-weight: bold; }
.signal-box { text-align: center; padding: 16px; border-radius: 6px; margin: 8px 0; }
.signal-box.buy { background: rgba(0,255,136,.1); border: 2px solid var(--green); }
.signal-box.sell { background: rgba(255,68,85,.1); border: 2px solid var(--red); }
.signal-box.hold { background: rgba(255,204,0,.1); border: 2px solid var(--yellow); }
.signal-label { font-size: 24px; font-weight: bold; letter-spacing: 4px; }
.signal-label.buy { color: var(--green); }
.signal-label.sell { color: var(--red); }
.signal-label.hold { color: var(--yellow); }
.bar-wrap { background: #111128; border-radius: 4px; height: 8px; margin: 6px 0; overflow: hidden; }
.bar-fill { height: 100%; border-radius: 4px; transition: width .6s ease; }
.bar-cyan { background: linear-gradient(90deg, var(--cyan), #0066ff); }
.bar-magenta { background: linear-gradient(90deg, var(--magenta), #aa00ff); }
.bar-green { background: linear-gradient(90deg, var(--green), #00aaff); }
.bar-gold { background: linear-gradient(90deg, var(--gold), #ff8800); }
.bar-red { background: linear-gradient(90deg, var(--red), var(--magenta)); }
.cea-badge { display: inline-block; background: rgba(0,212,255,.15); border: 1px solid var(--cyan); border-radius: 4px; padding: 2px 8px; font-size: 12px; color: var(--cyan); }
.lpi-badge { display: inline-block; background: rgba(255,0,170,.15); border: 1px solid var(--magenta); border-radius: 4px; padding: 2px 8px; font-size: 12px; color: var(--magenta); }
canvas { width: 100%; border-radius: 6px; }
.forecast-window { display: flex; justify-content: space-between; align-items: center; padding: 6px 8px; margin: 4px 0; border-radius: 4px; font-size: 12px; }
.fw-buy { background: rgba(0,255,136,.08); border-left: 3px solid var(--green); }
.fw-sell { background: rgba(255,68,85,.08); border-left: 3px solid var(--red); }
.trade-row { display: flex; justify-content: space-between; padding: 4px 6px; border-radius: 3px; margin: 2px 0; font-size: 11px; }
.trade-buy { background: rgba(0,255,136,.06); color: var(--green); }
.trade-sell { background: rgba(255,68,85,.06); color: var(--red); }
.trade-hold { background: rgba(255,204,0,.06); color: var(--yellow); }
.regime-pill { display: inline-block; padding: 2px 10px; border-radius: 12px; font-size: 11px; font-weight: bold; }
.regime-bull { background: rgba(0,255,136,.2); color: var(--green); border: 1px solid var(--green); }
.regime-bear { background: rgba(255,68,85,.2); color: var(--red); border: 1px solid var(--red); }
.regime-neutral { background: rgba(255,204,0,.2); color: var(--yellow); border: 1px solid var(--yellow); }
.backtest-stat { display: flex; justify-content: space-between; padding: 5px 0; border-bottom: 1px solid #111128; }
.bt-label { color: var(--dim); }
.bt-val { font-weight: bold; }
.bt-val.pos { color: var(--green); }
.bt-val.neg { color: var(--red); }
.loading-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(5,5,16,.9); display: flex; align-items: center; justify-content: center; z-index: 100; flex-direction: column; gap: 16px; }
.loading-text { color: var(--cyan); font-size: 16px; letter-spacing: 2px; }
.spinner { width: 48px; height: 48px; border: 3px solid var(--border); border-top-color: var(--cyan); border-radius: 50%; animation: spin 1s linear infinite; }
@keyframes spin { to{transform:rotate(360deg)} }
.error-msg { color: var(--red); font-size: 12px; padding: 4px 8px; background: rgba(255,68,85,.1); border-radius: 4px; margin-top: 4px; }
.tooltip { position: relative; cursor: help; }
.tooltip:hover::after { content: attr(data-tip); position: absolute; bottom: 120%; left: 50%; transform: translateX(-50%); background: #1a1a4e; border: 1px solid var(--cyan); color: var(--text); padding: 6px 10px; border-radius: 4px; font-size: 11px; white-space: nowrap; z-index: 10; }
footer { text-align: center; padding: 16px; color: var(--dim); font-size: 11px; border-top: 1px solid var(--border); margin-top: 8px; }
a { color: var(--cyan); text-decoration: none; }
@media (max-width: 600px) { .big-price { font-size: 24px; } header h1 { font-size: 14px; } }
</style>
