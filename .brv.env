# ByteRover Configuration
# Store in /Users/rk/clawd/.brv.env (not committed to git)

# LLM Provider - Using Anthropic (same as OpenClaw)
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}

# Vector Store - Use in-memory (local, no external services)
VECTOR_STORE_TYPE=in-memory

# Logging
CIPHER_LOG_LEVEL=info

# Redact secrets from logs
REDACT_SECRETS=true
