{
  "buildCommand": "echo 'static site'",
  "outputDirectory": ".",
  "public": true,
  "rewrites": [
    { "source": "/aurora", "destination": "/aurora.html" },
    { "source": "/consulting", "destination": "/consulting.html" },
    { "source": "/teslasales", "destination": "/teslasales.html" },
    { "source": "/tesla", "destination": "/tesla.html" },
    { "source": "/rork", "destination": "/rork/index.html" }
  ],
  "trailingSlash": false,
  "headers": [
    {
      "source": "/rork/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
}
