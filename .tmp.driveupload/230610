        <!-- LLM GUARDRAILS -->
        <h2 id="guardrails">🛡️ LLM Guardrails & Validation Rules</h2>
        
        <div class="section">
            <h3>Why Guardrails?</h3>
            <p>LLMs can hallucinate or suggest nonsensical combinations (e.g., "salty liquid" as a primary food). These 10 validation rules prevent bad suggestions from reaching parents.</p>

            <h3>Validation Rules (10 Total)</h3>
            <table>
                <tr>
                    <th>#</th>
                    <th>Rule</th>
                    <th>Prevents</th>
                </tr>
                <tr>
                    <td>1</td>
                    <td>Never suggest liquid foods as primary foods (except beverages)</td>
                    <td>"Try gravy" or "Try apple juice as lunch"</td>
                </tr>
                <tr>
                    <td>2</td>
                    <td>Avoid bitter flavors for selective eaters</td>
                    <td>Suggesting dark leafy greens, coffee, strong spices to hesitant kids</td>
                </tr>
                <tr>
                    <td>3</td>
                    <td>Don't combine 3+ bold flavors simultaneously</td>
                    <td>"Try salty + sour + spicy" (overwhelming sensory load)</td>
                </tr>
                <tr>
                    <td>4</td>
                    <td>Validate Temperature + Texture combos</td>
                    <td>Hot crunchy foods (e.g., crispy chips straight from fryer may be texture-jarring)</td>
                </tr>
                <tr>
                    <td>5</td>
                    <td>ONLY suggest foods in approved 100+ database</td>
                    <td>Random foods not validated for SOS approach</td>
                </tr>
                <tr>
                    <td>6</td>
                    <td>Enforce color variety (prevent monochrome diets)</td>
                    <td>Suggesting 10 brown foods when child already has brown</td>
                </tr>
                <tr>
                    <td>7</td>
                    <td>Require food group diversity</td>
                    <td>Suggesting only proteins; enforce cross-group balance</td>
                </tr>
                <tr>
                    <td>8</td>
                    <td>Bridge foods must share ≥1 sensory attribute with safe foods</td>
                    <td>Suggesting taco (mixed texture) to child who only eats crunchy foods</td>
                </tr>
                <tr>
                    <td>9</td>
                    <td>Sensory distance ≤1 step (texture diff ≤1, flavor ≤1)</td>
                    <td>Jumping from crackers to spicy salsa (too big of jump)</td>
                </tr>
                <tr>
                    <td>10</td>
                    <td>Weekly batch processing only (not real-time)</td>
                    <td>Recommendation spam; ensures thoughtful, considered suggestions</td>
                </tr>
            </table>

            <h3>Implementation (Pseudocode)</h3>
            <pre>function validateBridgeFoodSuggestion(suggestion, safefoods) {
  // Rule 5: Database check
  if (!FOOD_DATABASE.includes(suggestion)) return reject("Not in database");
  
  // Rule 1: Liquid check
  if (suggestion.texture === "liquid" && suggestion !== beverage) 
    return reject("Liquid foods not primary");
  
  // Rule 2: Bitter check
  if (suggestion.flavor === "bitter") return reject("Bitter flavor avoided");
  
  // Rule 3: Bold flavor check
  boldFlavors = suggestion.flavors.filter(f => f in ['salty','sour','spicy'])
  if (boldFlavors.length >= 3) return reject("Too many bold flavors");
  
  // Rule 6: Color variety
  usedColors = safefoods.map(f => f.color)
  if (suggestion.color in usedColors && colorCount < 8) 
    return reject("Use unused color first");
  
  // Rule 8: Sensory attribute overlap
  commonAttrs = suggestion.sensoryAttrs 
    & safefoods.map(f => f.sensoryAttrs)
  if (commonAttrs.length < 1) return reject("No sensory overlap");
  
  // Rule 9: Sensory distance
  distance = calculateSensoryDistance(suggestion, safefoods)
  if (distance > 1) return reject("Too big of sensory jump");
  
  return approve(suggestion);
}</pre>

            <h3>Forbidden Combos</h3>
            <ul>
                <li><strong>Salty + Liquid:</strong> Broth, salted water, salty dressings (primary foods only)</li>
                <li><strong>Bitter + Any:</strong> Blocked entirely for safety</li>
                <li><strong>Hot + Crunchy:</strong> Immediate sensory conflict (temperature changes texture perception)</li>
                <li><strong>3+ Bold Flavors:</strong> Salty+Sour+Spicy too overwhelming for selective eaters</li>
                <li><strong>Mushy + Sweet:</strong> Can trigger gag reflex in sensitive kids (proceed cautiously)</li>
            </ul>
        </div>

